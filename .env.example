# Runtime mode
APP_ENV=development
LOG_LEVEL=info

# Strict mode controls for task preflight.
# - development: STRICT_ENV=false keeps API keys optional.
# - production tasks: STRICT_ENV=true requires non-placeholder secrets.
STRICT_ENV=false
STRICT_REQUIRE_RENDER=false

# Project paths (used by Go service)
RAW_DIR=./raw
OUTPUT_DIR=./output
STATE_DIR=./state

# Pipeline limits
MAX_VIDEO_DURATION_SEC=60
TTS_DAILY_LIMIT=2000

# Optional manual selection (empty = random unprocessed)
CONTENT_NUM=

# z.ai / GLM (required when STRICT_ENV=true)
ZAI_API_KEY=replace_me
ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.7

# AI scenes (OpenAI-compatible image generation)
# In strict mode at least one key must be set: IMAGE_API_KEY or OPENAI_API_KEY.
IMAGE_API_KEY=
OPENAI_API_KEY=
IMAGE_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_BASE_URL=
IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_MODEL=
IMAGE_SIZE=1024x1536
IMAGE_REQUEST_TIMEOUT_SEC=45
IMAGE_MAX_RETRIES=2
IMAGE_RETRY_BACKOFF_MS=1000
SCENE_HERO_PROFILE=харизматичный инженер в бирюзовой худи, главный герой техно-истории

# Yandex SpeechKit (required when STRICT_ENV=true)
YANDEX_API_KEY=replace_me
YANDEX_FOLDER_ID=replace_me
YANDEX_TTS_VOICE=jane
YANDEX_TTS_EMOTION=good
YANDEX_TTS_SPEED=1.0
YANDEX_TTS_FORMAT=mp3

# Puppeteer service and smoke checks
# Local runs usually use http://127.0.0.1:3000/render.
PUPPETEER_PORT=3000
PUPPETEER_SERVICE_URL=http://puppeteer:3000/render
PUPPETEER_BASE_URL=
PUPPETEER_TIMEOUT_SEC=120
PUPPETEER_HEALTH_URL=http://127.0.0.1:3000/health
PUPPETEER_HEALTH_INTERVAL=10s
PUPPETEER_HEALTH_TIMEOUT=5s
PUPPETEER_HEALTH_RETRIES=10
PUPPETEER_HEALTH_START_PERIOD=20s

# Tooling
FFMPEG_BIN=ffmpeg
